{
  "name": "Minimal Python Dev Container",
  "features": {
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.11",
      "installJupyterlab": true
    }
  },
  "workspaceFolder": "/home/user",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter"
      ]
    }
  },
  "forwardPorts": [7860],
  "portsAttributes": {
    "7860": {
      "label": "EDPS App",
      "visibility": "public"
    }
  }
}

